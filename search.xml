        <content type="html"><![CDATA[<p><img src="/2020/11/04/java-2/aa.jpg"></p><figure class="highlight plain"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br><span class="line">12</span><br><span class="line">13</span><br><span class="line">14</span><br><span class="line">15</span><br><span class="line">16</span><br><span class="line">17</span><br><span class="line">18</span><br><span class="line">19</span><br><span class="line">20</span><br><span class="line">21</span><br><span class="line">22</span><br><span class="line">23</span><br><span class="line">24</span><br><span class="line">25</span><br><span class="line">26</span><br><span class="line">27</span><br><span class="line">28</span><br><span class="line">29</span><br><span class="line">30</span><br><span class="line">31</span><br><span class="line">32</span><br><span class="line">33</span><br><span class="line">34</span><br><span class="line">35</span><br><span class="line">36</span><br><span class="line">37</span><br><span class="line">38</span><br><span class="line">39</span><br><span class="line">40</span><br><span class="line">41</span><br><span class="line">42</span><br><span class="line">43</span><br><span class="line">44</span><br><span class="line">45</span><br><span class="line">46</span><br><span class="line">47</span><br><span class="line">48</span><br><span class="line">49</span><br><span class="line">50</span><br><span class="line">51</span><br><span class="line">52</span><br><span class="line">53</span><br><span class="line">54</span><br><span class="line">55</span><br><span class="line">56</span><br><span class="line">57</span><br><span class="line">58</span><br><span class="line">59</span><br><span class="line">60</span><br><span class="line">61</span><br><span class="line">62</span><br><span class="line">63</span><br><span class="line">64</span><br><span class="line">65</span><br><span class="line">66</span><br><span class="line">67</span><br><span class="line">68</span><br><span class="line">69</span><br><span class="line">70</span><br><span class="line">71</span><br><span class="line">72</span><br><span class="line">73</span><br><span class="line">74</span><br><span class="line">75</span><br><span class="line">76</span><br><span class="line">77</span><br><span class="line">78</span><br><span class="line">79</span><br><span class="line">80</span><br><span class="line">81</span><br><span class="line">82</span><br><span class="line">83</span><br><span class="line">84</span><br><span class="line">85</span><br><span class="line">86</span><br><span class="line">87</span><br><span class="line">88</span><br><span class="line">89</span><br><span class="line">90</span><br><span class="line">91</span><br><span class="line">92</span><br><span class="line">93</span><br><span class="line">94</span><br><span class="line">95</span><br><span class="line">96</span><br><span class="line">97</span><br><span class="line">98</span><br><span class="line">99</span><br><span class="line">100</span><br><span class="line">101</span><br><span class="line">102</span><br><span class="line">103</span><br><span class="line">104</span><br><span class="line">105</span><br><span class="line">106</span><br><span class="line">107</span><br><span class="line">108</span><br><span class="line">109</span><br><span class="line">110</span><br><span class="line">111</span><br><span class="line">112</span><br><span class="line">113</span><br><span class="line">114</span><br><span class="line">115</span><br><span class="line">116</span><br><span class="line">117</span><br><span class="line">118</span><br><span class="line">119</span><br><span class="line">120</span><br><span class="line">121</span><br><span class="line">122</span><br><span class="line">123</span><br><span class="line">124</span><br><span class="line">125</span><br><span class="line">126</span><br><span class="line">127</span><br><span class="line">128</span><br><span class="line">129</span><br><span class="line">130</span><br><span class="line">131</span><br><span class="line">132</span><br><span class="line">133</span><br><span class="line">134</span><br><span class="line">135</span><br><span class="line">136</span><br><span class="line">137</span><br><span class="line">138</span><br><span class="line">139</span><br><span class="line">140</span><br><span class="line">141</span><br><span class="line">142</span><br><span class="line">143</span><br><span class="line">144</span><br><span class="line">145</span><br><span class="line">146</span><br><span class="line">147</span><br><span class="line">148</span><br><span class="line">149</span><br><span class="line">150</span><br><span class="line">151</span><br><span class="line">152</span><br><span class="line">153</span><br><span class="line">154</span><br><span class="line">155</span><br><span class="line">156</span><br><span class="line">157</span><br><span class="line">158</span><br><span class="line">159</span><br><span class="line">160</span><br><span class="line">161</span><br><span class="line">162</span><br><span class="line">163</span><br><span class="line">164</span><br><span class="line">165</span><br><span class="line">166</span><br><span class="line">167</span><br><span class="line">168</span><br><span class="line">169</span><br><span class="line">170</span><br><span class="line">171</span><br><span class="line">172</span><br><span class="line">173</span><br><span class="line">174</span><br><span class="line">175</span><br><span class="line">176</span><br><span class="line">177</span><br><span class="line">178</span><br><span class="line">179</span><br><span class="line">180</span><br><span class="line">181</span><br><span class="line">182</span><br><span class="line">183</span><br><span class="line">184</span><br><span class="line">185</span><br><span class="line">186</span><br><span class="line">187</span><br></pre></td><td class="code"><pre><code class="hljs plain">JAVAд»Јз Ғ<br>package com.example.lx_webview;<br><br>import android.support.v7.app.AppCompatActivity;<br>import android.os.Bundle;<br>import android.text.TextUtils;<br>import android.view.View;<br>import android.webkit.WebChromeClient;<br>import android.webkit.WebSettings;<br>import android.webkit.WebView;<br>import android.webkit.WebViewClient;<br>import android.widget.Button;<br>import android.widget.EditText;<br>import android.widget.ProgressBar;<br>import android.widget.Toast;<br><br>import java.util.concurrent.TimeUnit;<br><br>public class MainActivity extends AppCompatActivity implements View.OnClickListener &#123;<br><br>    private WebView www_wb;<br>    private ProgressBar webView_pb;<br>    private EditText path_et;<br>    private View btn;<br><br>    @Override<br>    protected void onCreate(Bundle savedInstanceState) &#123;<br>        super.onCreate(savedInstanceState);<br>        setContentView(R.layout.activity_main);<br>        &#x2F;&#x2F;еҲқе§ӢеҢ–<br>        initView();<br>        &#x2F;&#x2F;дҪҝз”ЁwebviewеҜ№иұЎпјҢиҝӣиЎҢеҲқе§ӢеҢ–<br>        webViewinit();<br>        &#x2F;&#x2F;еҫ—еҲ°webviewSettingsеҜ№webviewиҝӣиЎҢеҲқе§ӢеҢ–и®ҫзҪ®<br>        webviewSettingSInit();<br>    &#125;<br><br>    &#x2F;&#x2F;зӮ№еҮ»дәӢд»¶<br>    @Override<br>    public void onClick(View v) &#123;<br>        switch (v.getId())&#123;<br>            case R.id.btn:<br>                String trim &#x3D; path_et.getText().toString().trim();<br>                if (TextUtils.isEmpty(trim))&#123;<br>                    Toast.makeText(this,&quot;дёҚиғҪиҫ“е…Ҙдёәз©ә&quot;,Toast.LENGTH_SHORT).show();<br>                    return;<br>                &#125;<br>                www_wb.loadUrl(&quot;http:&#x2F;&#x2F;&quot;+trim);<br>                break;<br>        &#125;<br><br>    &#125;<br>    &#x2F;&#x2F;еҫ—еҲ°webviewSettingsеҜ№webviewиҝӣиЎҢеҲқе§ӢеҢ–и®ҫзҪ®<br>    private void webviewSettingSInit() &#123;<br>        WebSettings settings &#x3D; www_wb.getSettings();<br>        &#x2F;&#x2F;е…Ғи®ёjsдәӨдә’<br>        settings.setJavaScriptEnabled(true);<br>        &#x2F;&#x2F;и®ҫзҪ®еҸҜд»Ҙж”ҜжҢҒзј©ж”ҫ<br>        settings.setSupportZoom(true);<br>    &#125;<br>    &#x2F;&#x2F;дҪҝз”ЁwebviewеҜ№иұЎпјҢиҝӣиЎҢеҲқе§ӢеҢ–<br>    private void webViewinit() &#123;<br>        &#x2F;&#x2F;зӮ№еҮ»еңЁAppеҶ…жү§иЎҢ<br>        www_wb.setWebViewClient(new WebViewClient());<br>        &#x2F;&#x2F;WebViewеҠ иҪҪзҪ‘йЎөзӣ‘еҗ¬пјҢе…¶иҝӣеәҰе’ҢжҲ‘д»¬зҡ„иҝӣеәҰжқЎзӣёз»‘е®ҡпјҢз„¶еҗҺжҳҫзӨәеҮәжҲ‘д»¬д№ҹжғізҡ„ж•Ҳжһң<br>        www_wb.setWebChromeClient(new WebChromeClient()&#123;<br>            &#x2F;&#x2F;ж–№жі•дёӯзҡ„onProgressChangedе°ұд»ЈиЎЁдәҶе…¶йҖҹеәҰ<br>            @Override<br>            public void onProgressChanged(WebView view, int newProgress) &#123;<br>                &#x2F;&#x2F;йҰ–е…ҲжҲ‘д»¬зҡ„иҝӣеәҰжқЎжҳҜйҡҗи—Ҹзҡ„<br>                webView_pb.setVisibility(View.VISIBLE);<br>                &#x2F;&#x2F;жҠҠзҪ‘йЎөеҠ иҪҪзҡ„иҝӣеәҰдј з»ҷжҲ‘д»¬зҡ„иҝӣеәҰжқЎ<br>                webView_pb.setProgress(newProgress);<br>                if (newProgress &#x3D;&#x3D; 100)&#123;<br>                    &#x2F;&#x2F;еҠ иҪҪе®ҢжҜ•и®©иҝӣеәҰжқЎж¶ҲеӨұ<br>                    webView_pb.setVisibility(View.GONE);<br>                &#125;<br>                super.onProgressChanged(view, newProgress);<br>            &#125;<br>        &#125;);<br>    &#125;<br>    &#x2F;&#x2F;еҲқе§ӢеҢ–<br>    private void initView() &#123;<br>        path_et &#x3D; findViewById(R.id.path_et);<br>        webView_pb &#x3D; findViewById(R.id.pb);<br>        www_wb &#x3D; findViewById(R.id.www_wb);<br>        btn &#x3D; findViewById(R.id.btn);<br>        btn.setOnClickListener(this);<br>    &#125;<br><br><br>&#125;<br><br>еёғеұҖXMLд»Јз Ғ<br>&lt;?xml version&#x3D;&quot;1.0&quot; encoding&#x3D;&quot;utf-8&quot;?&gt;<br>&lt;LinearLayout xmlns:android&#x3D;&quot;http:&#x2F;&#x2F;schemas.android.com&#x2F;apk&#x2F;res&#x2F;android&quot;<br>    xmlns:tools&#x3D;&quot;http:&#x2F;&#x2F;schemas.android.com&#x2F;tools&quot;<br>    android:layout_width&#x3D;&quot;match_parent&quot;<br>    android:layout_height&#x3D;&quot;match_parent&quot;<br>    android:orientation&#x3D;&quot;vertical&quot;&gt;<br><br>    &lt;!--  з”ЁеҲ°дәҶжқғйҮҚзҹҘиҜҶ,progressиҝӣеәҰжқЎжЁЎејҸ:style&#x3D;&quot;?android:attr&#x2F;progressBarStyleHorizontal&quot;  --&gt;<br>    &lt;LinearLayout<br>        android:layout_width&#x3D;&quot;match_parent&quot;<br>        android:layout_height&#x3D;&quot;wrap_content&quot;<br>        android:orientation&#x3D;&quot;horizontal&quot;&gt;<br>        &lt;EditText<br>            android:id&#x3D;&quot;@+id&#x2F;path_et&quot;<br>            android:layout_width&#x3D;&quot;match_parent&quot;<br>            android:layout_weight&#x3D;&quot;1&quot;<br>            android:layout_height&#x3D;&quot;wrap_content&quot;<br>            android:singleLine&#x3D;&quot;true&quot;<br>            android:hint&#x3D;&quot;иҜ·з”ЁжҲ·иҫ“е…ҘзҪ‘еқҖ,зӣҙжҺҘд»ҺwwwејҖе§ӢеҚіеҸҜ&quot;<br>            &#x2F;&gt;<br>        &lt;Button<br>            android:id&#x3D;&quot;@+id&#x2F;btn&quot;<br>            android:layout_width&#x3D;&quot;wrap_content&quot;<br>            android:layout_height&#x3D;&quot;wrap_content&quot;<br>            android:text&#x3D;&quot;еҠ иҪҪзҪ‘йЎө&quot;<br><br>            &#x2F;&gt;<br>    &lt;&#x2F;LinearLayout&gt;<br><br>    &lt;ProgressBar<br>        android:id&#x3D;&quot;@+id&#x2F;pb&quot;<br>        android:layout_width&#x3D;&quot;match_parent&quot;<br>        android:layout_height&#x3D;&quot;wrap_content&quot;<br>        style&#x3D;&quot;?android:attr&#x2F;progressBarStyleHorizontal&quot;<br>        android:max&#x3D;&quot;100&quot;<br>        android:visibility&#x3D;&quot;gone&quot;<br>        &#x2F;&gt;<br><br>    &lt;WebView<br>        android:id&#x3D;&quot;@+id&#x2F;www_wb&quot;<br>        android:layout_width&#x3D;&quot;match_parent&quot;<br>        android:layout_height&#x3D;&quot;match_parent&quot;<br>        android:layout_weight&#x3D;&quot;1&quot;&gt;<br>    &lt;&#x2F;WebView&gt;<br><br><br>&lt;&#x2F;LinearLayout&gt;<br><br>progressbarж ·ејҸ<br>&lt;?xml version&#x3D;&quot;1.0&quot; encoding&#x3D;&quot;utf-8&quot;?&gt;<br>&lt;layer-list xmlns:android&#x3D;&quot;http:&#x2F;&#x2F;schemas.android.com&#x2F;apk&#x2F;res&#x2F;android&quot; &gt;<br><br>    &lt;item android:id&#x3D;&quot;@android:id&#x2F;background&quot;&gt;<br>        &lt;shape&gt;<br>            &lt;corners android:radius&#x3D;&quot;5dp&quot; &#x2F;&gt;<br><br>            &lt;gradient<br>                android:angle&#x3D;&quot;0&quot;<br>                android:centerColor&#x3D;&quot;#fff0f1f0&quot;<br>                android:centerY&#x3D;&quot;0.75&quot;<br>                android:endColor&#x3D;&quot;#ffdee0de&quot;<br>                android:startColor&#x3D;&quot;#ffffffff&quot; &#x2F;&gt;<br>        &lt;&#x2F;shape&gt;<br>    &lt;&#x2F;item&gt;<br>    &lt;item android:id&#x3D;&quot;@android:id&#x2F;secondaryProgress&quot;&gt;<br>        &lt;clip&gt;<br>            &lt;shape&gt;<br>                &lt;corners android:radius&#x3D;&quot;5dp&quot; &#x2F;&gt;<br><br>                &lt;gradient<br>                    android:angle&#x3D;&quot;0&quot;<br>                    android:centerColor&#x3D;&quot;#F39801&quot;<br>                    android:centerY&#x3D;&quot;0.75&quot;<br>                    android:endColor&#x3D;&quot;#a0ffcb00&quot;<br>                    android:startColor&#x3D;&quot;#80ffd300&quot; &#x2F;&gt;<br>            &lt;&#x2F;shape&gt;<br>        &lt;&#x2F;clip&gt;<br>    &lt;&#x2F;item&gt;<br>    &lt;item android:id&#x3D;&quot;@android:id&#x2F;progress&quot;&gt;<br>        &lt;clip&gt;<br>            &lt;shape&gt;<br>                &lt;corners android:radius&#x3D;&quot;5dip&quot; &#x2F;&gt;<br><br>                &lt;gradient<br>                    android:angle&#x3D;&quot;0&quot;<br>                    android:endColor&#x3D;&quot;#8000ff00&quot;<br>                    android:startColor&#x3D;&quot;#80ff0000&quot; &#x2F;&gt;<br>            &lt;&#x2F;shape&gt;<br>        &lt;&#x2F;clip&gt;<br>    &lt;&#x2F;item&gt;<br><br>&lt;&#x2F;layer-list&gt;<br><br></code></pre></td></tr></table></figure>]]></content>
      
      
      
